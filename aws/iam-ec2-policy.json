{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadERPSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:ap-northeast-2:*:secret:erp/*"
    }
  ]
}
